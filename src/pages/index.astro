---
import { getCollection } from 'astro:content';
import Terminal from '@components/Terminal';
import '@styles/terminal.css';
import type { ResumeEntry } from '@components/commands/Resume';
import type { ProjectEntry } from '@components/commands/Projects';
import type { BlogEntry } from '@components/commands/Blog';

// ── Fetch & serialize content collections at build time ────
// IMPORTANT: All data must be serialized to plain JSON before passing
// to the client:only React island — it has no access to Astro server APIs.

const rawResume = await getCollection('resume');
const resume: ResumeEntry[] = rawResume
  .map((e) => ({
    section: e.data.section,
    title:   e.data.title,
    organization: e.data.organization,
    location: e.data.location,
    start:   e.data.start,
    end:     e.data.end,
    link:    e.data.link,
    bullets: e.data.bullets,
  }))
  // Sort experience/education by start date desc, highlights first
  .sort((a, b) => {
    if (a.section === b.section) return b.start.localeCompare(a.start);
    const order = { experience: 0, education: 1, highlight: 2 };
    return order[a.section] - order[b.section];
  });

const rawProjects = await getCollection('projects');
const projects: ProjectEntry[] = rawProjects
  .sort((a, b) => {
    // Respect sortOrder if set, then fall back to launchedAt desc
    const aOrder = a.data.sortOrder ?? 999;
    const bOrder = b.data.sortOrder ?? 999;
    if (aOrder !== bOrder) return aOrder - bOrder;
    return b.data.launchedAt.getTime() - a.data.launchedAt.getTime();
  })
  .map((p) => ({
    slug:       p.slug,
    title:      p.data.title,
    summary:    p.data.summary,
    tags:       p.data.tags,
    links:      p.data.links,
    launchedAt: p.data.launchedAt.toISOString(),
    // Omit heroImage — ImageMetadata is not serializable
  }));

const rawBlog = await getCollection('blog');
const blog: BlogEntry[] = rawBlog
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .map((p) => ({
    slug:        p.slug,
    title:       p.data.title,
    description: p.data.description,
    pubDate:     p.data.pubDate.toISOString(),
    tags:        p.data.tags,
    readingTime: p.data.readingTime,
    // Omit heroImage
  }));

const title = 'Joshua Mason — Terminal Portfolio';
const description = 'ML engineer specializing in search & relevance. Interactive terminal portfolio.';
const ogImage = '/headshot-small.jpg';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Joshua Mason" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.joshua-mason.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: IBM Plex Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Joshua Mason — Blog" href="/rss.xml" />

    <!-- Structured data -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Joshua Mason",
        "url": "https://www.joshua-mason.com",
        "jobTitle": "ML Engineer",
        "sameAs": [
          "https://github.com/joshuam1008",
          "https://www.linkedin.com/in/joshuam1008/"
        ]
      })}
    </script>

    <!-- Apply saved theme before first paint to avoid flash -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('terminal-theme');
        if (saved) document.documentElement.setAttribute('data-theme', saved);
      })();
    </script>
  </head>

  <body>
    <!-- Hidden h1 for screen readers and SEO crawlers -->
    <h1 class="sr-only">Joshua Mason — Terminal Portfolio</h1>

    <Terminal
      resume={resume}
      projects={projects}
      blog={blog}
      client:only="react"
    />
  </body>
</html>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
